# ─────────────────────────────────────────────────────────────
#  Rent Manager — Environment Variables
#  Copy this file to .env and fill in your values:
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database Provider ─────────────────────────────────────────
# "sqlite"  → local development (default, no extra setup)
# "mysql"   → cPanel / production (requires MySQL credentials below)
DB_PROVIDER="sqlite"

# ── Database URL ──────────────────────────────────────────────
# SQLite (used when DB_PROVIDER=sqlite)
DATABASE_URL="file:./dev.db"

# MySQL (used when DB_PROVIDER=mysql) — fill in your cPanel credentials:
# DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"

# ── Tenant Portal ─────────────────────────────────────────────
# "true"  → enable /portal/* routes for tenants
# "false" → disable all portal routes (returns 404)
TENANT_PORTAL_ENABLED="true"

# ── App URL ───────────────────────────────────────────────────
# Used in WhatsApp magic links sent to tenants
# Local:      http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
