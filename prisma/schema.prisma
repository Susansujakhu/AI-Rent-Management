// ── MySQL schema for cPanel deployment ───────────────────────────────────────
// When deploying to cPanel/MySQL:
//   1. Copy this file over prisma/schema.prisma
//   2. Set DATABASE_URL="mysql://user:pass@localhost:3306/dbname" in .env
//   3. Run: npx prisma db push
//   4. Import export.sql via phpMyAdmin
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  phone         String?   @unique
  phoneVerified Boolean   @default(false)
  role                 String    @default("user")  // "user" | "admin"
  plan                 String    @default("free")  // "free" | "basic" | "starter" | "pro"
  planExpiresAt        DateTime?
  billingCycle         String?                     // "monthly" | "yearly"
  upgradeRequestedAt   DateTime?
  pendingPlan          String?                     // plan tier from upgrade request
  pendingBillingCycle  String?                     // billing cycle from upgrade request
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions             Session[]
  rooms                Room[]
  tenants              Tenant[]
  payments             Payment[]
  expenses             Expense[]
  recurringCharges     RecurringCharge[]
  oneTimeCharges       OneTimeCharge[]
  settings             Setting[]
  passwordResets       PasswordResetToken[]
  subscriptionHistory  SubscriptionHistory[]
  paymentTransactions  PaymentTransaction[]
  chargeTransactions   ChargeTransaction[]
  maintenanceRequests  MaintenanceRequest[]
  documents            TenantDocument[]
  meterReadings        MeterReading[]
  notifications        Notification[]
  paymentClaims        PaymentClaim[]
  whatsAppMessages     WhatsAppMessage[]
  rentHistory          RentHistory[]
  settlements          Settlement[]
}

model SubscriptionHistory {
  id           String    @id @default(cuid())
  userId       String
  plan         String                            // plan set at this point
  billingCycle String?                           // "monthly" | "yearly"
  expiresAt    DateTime?                         // expiry date set
  note         String?   @db.Text
  changedBy    String    @default("admin")       // "admin" | "system"
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhoneVerificationToken {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  otp       String   // 6-digit code
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])                 // logout / session list
  @@index([expiresAt])              // cleanup cron
}

model Room {
  id          String   @id @default(cuid())
  userId      String
  name        String
  floor       String?
  monthlyRent Float
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenants          Tenant[]
  payments         Payment[]
  expenses         Expense[]
  recurringCharges RecurringCharge[]
  rentHistory      RentHistory[]
}

// Every rent change for a room. Room.monthlyRent stays as the *current* rent
// (denormalised cache of the latest history row) so existing queries keep
// working without rewrites; this table is the source of truth for "what was
// the rent during month X".
model RentHistory {
  id            String   @id @default(cuid())
  userId        String
  roomId        String
  amount        Float
  effectiveFrom String                                // "YYYY-MM" — month the rate kicks in
  reason        String?  @db.Text
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, effectiveFrom])
  @@index([userId])
}

model Tenant {
  id             String    @id @default(cuid())
  userId         String
  name           String
  phone          String
  email          String?
  roomId         String?
  moveInDate     DateTime
  moveOutDate    DateTime?
  deposit        Float     @default(0)
  creditBalance  Float     @default(0)
  notes          String?   @db.Text
  whatsappNotify Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  portalEnabled Boolean  @default(false)
  portalToken   String?  @unique

  canSubmitMeterReading  Boolean @default(false)
  meterReadingAutoAccept Boolean @default(false)
  electricityRate        Float?  // per-tenant override; falls back to global electricityRate setting

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  room               Room?               @relation(fields: [roomId], references: [id])
  payments           Payment[]
  oneTimeCharges     OneTimeCharge[]
  recurringCharges   RecurringCharge[]
  portalSessions     TenantSession[]
  chargeTransactions ChargeTransaction[]
  maintenanceRequests MaintenanceRequest[]
  documents          TenantDocument[]
  meterReadings      MeterReading[]
  paymentClaims      PaymentClaim[]
  whatsAppMessages   WhatsAppMessage[]
  settlement         Settlement?

  @@index([userId, moveOutDate])    // active tenants query
}

model Payment {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  roomId     String
  month      String
  amountDue  Float
  amountPaid Float     @default(0)
  paidDate   DateTime?
  method     String?
  status     String    @default("PENDING")
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room         Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]
  paymentClaims PaymentClaim[]

  @@unique([tenantId, month])
  @@index([userId, month])      // dashboard month queries
  @@index([userId, status])     // open bills / overdue counts
  @@index([tenantId])           // tenant ledger lookups
}

// A tenant-reported payment — "I paid X via Y." This is a CLAIM, not a
// recorded payment: the owner must verify the money arrived and then record
// it through the normal payment flow. Status tracks the review lifecycle.
model PaymentClaim {
  id         String    @id @default(cuid())
  userId     String                       // owner (landlord) — for scoping
  tenantId   String
  paymentId  String?                      // the bill this is reported against (optional)
  amount        Float
  method        String                    // "eSewa" | "Khalti" | "Bank" | "Cash" | ...
  reference     String?                   // optional txn id / reference the tenant entered
  paidDate      DateTime                  // when the tenant says they paid
  note          String?   @db.Text
  screenshotPath String?                  // optional proof-of-payment image filename
  status        String    @default("pending") // "pending" | "confirmed" | "rejected"
  reviewedAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, status])     // owner's pending-claims queue
  @@index([tenantId, status])   // tenant's "awaiting confirmation" badges
}

model PaymentTransaction {
  id           String   @id @default(cuid())
  userId       String
  paymentId    String
  amount       Float                 // amount applied to this specific payment
  creditAmount Float    @default(0)  // amount that went to credit balance from this session
  totalEntered Float    @default(0)  // total cash entered by user (only set on initiating transaction)
  method       String?
  paidAt       DateTime
  note         String?  @db.Text
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])              // receipt / history lookups
  @@index([userId, paidAt])         // payments page session grouping
}

// Tracks each charge that was paid (either via rent payment session or standalone)
model ChargeTransaction {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String
  chargeId    String
  chargeTitle String                 // snapshot of title at time of payment
  amount      Float                  // amount applied to this charge
  method      String?
  paidAt      DateTime               // matches PaymentTransaction.paidAt for same session
  note        String?  @db.Text
  createdAt   DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charge OneTimeCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@index([chargeId])               // void / history per charge
  @@index([tenantId, paidAt])       // session grouping on payments page
  @@index([userId, paidAt])         // payments page all-transactions query
}

model RecurringCharge {
  id            String   @id @default(cuid())
  userId        String
  roomId        String
  tenantId      String?
  title         String
  amount        Float
  effectiveFrom String?
  effectiveTo   String?  // last month this charge applies (YYYY-MM); null = still active
  createdAt     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  room   Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model OneTimeCharge {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  title      String
  amount     Float
  amountPaid Float    @default(0)
  date       DateTime
  status     String   @default("PENDING")
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions ChargeTransaction[]
  meterReading MeterReading?

  @@index([userId, status])         // open bills query
  @@index([tenantId])               // tenant charges panel
  @@index([userId, date])           // date-range queries
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  title       String
  amount      Float
  date        DateTime
  category    String   @default("OTHER")
  roomId      String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([userId, date])           // reports / expense list
  @@index([userId, category])       // category breakdown
}

model Setting {
  userId String
  key    String
  value  String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
}

// ── Tenant Documents ──────────────────────────────────────────────────────────

model TenantDocument {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  name      String           // original file name (display)
  fileName  String           // stored on disk as: {id}.{ext}
  mimeType  String
  size      Int              // bytes
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

// ── Electricity Meter Readings ────────────────────────────────────────────────

model MeterReading {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  month       String            // "YYYY-MM"
  previous    Float
  current     Float
  ratePerUnit Float
  unitsUsed   Float             // current - previous
  amount      Float             // unitsUsed * ratePerUnit
  chargeId    String?  @unique  // linked OneTimeCharge (null if charge not created)
  photoPath   String?           // optional meter photo filename
  notes       String?  @db.Text
  submittedByTenant Boolean @default(false)
  status            String  @default("confirmed") // "confirmed" | "pending_review"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charge OneTimeCharge? @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, month])
  @@index([userId, month])
}

// ── Maintenance Requests ──────────────────────────────────────────────────────

model MaintenanceRequest {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  title       String
  description String?   @db.Text
  category    String    @default("OTHER")   // PLUMBING | ELECTRICAL | APPLIANCE | STRUCTURAL | PEST | OTHER
  priority    String    @default("MEDIUM")  // LOW | MEDIUM | HIGH | URGENT
  status      String    @default("OPEN")    // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  notes       String?   @db.Text            // landlord response/notes
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([tenantId])
}

// ── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "meter_reading_submitted" | "meter_reading_updated" | "meter_reading_deleted"
  title     String
  body      String   @db.Text
  data      String?  @db.Text  // JSON: { tenantId, readingId, month }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ── Tenant Portal ────────────────────────────────────────────────────────────

// ── Global App Config ─────────────────────────────────────────────────────────

model GlobalSetting {
  key   String @id
  value String @db.Text
}

// ── WhatsApp Inbox — messages received via the Cloud API webhook ──────────────

model WhatsAppMessage {
  id            String   @id @default(cuid())
  userId        String                       // the owner this inbox belongs to
  tenantId      String?                      // matched by phone; null if sender unknown
  direction     String                       // "in" or "out"
  phone         String                       // E.164 normalized, e.g. "+9779812345678"
  body          String   @db.Text
  metaMessageId String?  @unique             // Meta's wamid, used to dedup webhook retries
  status        String?                      // sent / delivered / read / failed (outbound only)
  readByOwner   Boolean  @default(false)
  createdAt     DateTime @default(now())

  user   User    @relation(fields: [userId],   references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId, tenantId, createdAt])
  @@index([userId, readByOwner])
}

// ── Move-out Settlement ──────────────────────────────────────────────────────

// Snapshot of the final account when a tenant moves out: outstanding dues +
// damage deductions, settled against credit balance and security deposit.
// `detail` holds the full line-item JSON used by the statement page and a
// reversal ledger (`applied`) so a settlement can be voided cleanly.
model Settlement {
  id             String   @id @default(cuid())
  userId         String
  tenantId       String   @unique
  moveOutDate    DateTime
  totalDue       Float                  // outstanding rent + charges + deductions at settlement
  creditApplied  Float    @default(0)
  depositHeld    Float
  depositApplied Float
  refundDue      Float                  // owner owes tenant (leftover deposit + credit)
  balanceDue     Float                  // tenant still owes after deposit + credit
  detail         String?  @db.Text      // JSON: { finalMonth, lines, deductions, applied, deletedFuture }
  notes          String?  @db.Text
  createdAt      DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TenantSession {
  id        String   @id @default(cuid())
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
