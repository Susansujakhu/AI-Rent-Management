# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules/*
!/node_modules/.prisma
/node_modules/.prisma/*
!/node_modules/.prisma/client
/node_modules/.prisma/client/*.node
/node_modules/.prisma/client/*.tmp*
/node_modules/.prisma/client/*wasm-base64*
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
# /.next/ — temporarily included for cPanel deployment
/.next/cache/
/.next/dev/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# SQLite database files (contain real tenant/payment data)
*.db
*.db-journal
*.db-wal
*.db-shm

# Local app settings file (superseded by DB-backed settings)
app-settings.json

# WhatsApp session & Puppeteer cache (runtime data, regenerated on each login)
.wwebjs_auth/
.wwebjs_cache/

# MySQL data export (generated file, contains real data)
export.sql

# Prisma schema backup created by setup.mjs during MySQL switch
prisma/schema.sqlite.prisma

# Video production assets (scripts, storyboards, raw footage — not for deployment)
/video-assets/

# Tenant document uploads (uploaded at runtime — must exist on server but not in git)
/storage/
